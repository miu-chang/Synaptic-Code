{
  "name": "synaptic-code",
  "version": "0.1.3",
  "description": "Local LLM-powered coding assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "synaptic": "dist/index.js",
    "syn": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "pkg:win": "pkg . --targets node18-win-x64 --output dist/synaptic-win.exe",
    "pkg:mac": "pkg . --targets node18-macos-x64 --output dist/synaptic-macos",
    "pkg:linux": "pkg . --targets node18-linux-x64 --output dist/synaptic-linux",
    "pkg:all": "npm run pkg:win && npm run pkg:mac && npm run pkg:linux"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "dist/**/*"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "llm",
    "cli",
    "coding-assistant",
    "ollama",
    "lm-studio"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "glob": "^10.3.10",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.1",
    "marked-terminal": "^7.0.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "react-devtools-core": "^4.28.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
